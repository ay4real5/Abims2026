generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model RSVP {
  id            String   @id @default(cuid())
  status        String
  adultsCount   Int
  childrenCount Int
  infantsCount  Int
  primaryName   String
  primaryEmail  String
  primaryPhone  String?
  guests        Guest[]
  dietaryNotes  String?
  createdAt     DateTime @default(now())
}

model Guest {
  id      String @id @default(cuid())
  name    String
  rsvpId  String
  rsvp    RSVP   @relation(fields: [rsvpId], references: [id])
}
